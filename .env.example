# Callbell API Configuration
# Get these from your Callbell account (Settings → API)
CALLBELL_API_TOKEN=your-callbell-api-token-here
CALLBELL_IG_CHANNEL_UUID=your-instagram-channel-uuid-here
CALLBELL_WA_CHANNEL_UUID=your-whatsapp-channel-uuid-here

# Supabase Configuration
# These are automatically set in Supabase Edge Functions
# Only needed for local development
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Meta/Instagram Configuration (if using direct Meta API)
# Currently not used as we send via Callbell API
# META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
# META_IG_ACCOUNT_ID=your-instagram-account-id
# META_APP_SECRET=your-meta-app-secret
